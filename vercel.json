{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/main.py" },
    { "src": "/admin.html", "dest": "/public/admin.html" },
    { "src": "/pricing.html", "dest": "/public/pricing.html" },
    { "src": "/vip.html", "dest": "/public/vip.html" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
